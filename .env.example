# =============================================================================
# Gemini CLI — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# =============================================================================

# NOTE: With OAuth authentication (gemini login), no API key is required here.
# Tokens are stored in the 'gemini-config' Docker volume automatically.
# This file is kept for future use or switching to API key auth.

# Optional: uncomment and set if you prefer API key authentication instead of OAuth
# GEMINI_API_KEY=your_api_key_here

# Optional: override the Gemini model (default: gemini-2.5-pro)
# GEMINI_MODEL=gemini-2.0-flash

# =============================================================================
# Telegram Bot Configuration
# =============================================================================
# Get token from @BotFather in Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your chat ID from @userinfobot or @getmyid_bot
# ALLOWED_CHAT_ID=your_chat_id_here
